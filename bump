#!/usr/bin/env bash
set -euo pipefail

# Usage: ./bump 1.2.5
# Updates the version in all required files (Cargo.toml, pyproject.toml, sub-crate pyproject.tomls).

if [ $# -ne 1 ]; then
    echo "Usage: ./bump <new-version>"
    echo "Example: ./bump 1.2.5"
    exit 1
fi

NEW="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Read current version from workspace Cargo.toml
OLD=$(grep '^version = "' Cargo.toml | head -1 | sed 's/version = "\(.*\)"/\1/')

if [ "$OLD" = "$NEW" ]; then
    echo "Already at version $NEW"
    exit 0
fi

echo "Bumping $OLD → $NEW"

# Update all files
sed -i "s/$OLD/$NEW/g" Cargo.toml
sed -i "s/$OLD/$NEW/g" pyproject.toml
sed -i "s/$OLD/$NEW/g" crates/zccache-watcher/pyproject.toml
sed -i "s/$OLD/$NEW/g" crates/zccache-fingerprint/pyproject.toml

# Verify
COUNT=$(grep -c "$NEW" Cargo.toml)
echo "  Cargo.toml: $COUNT occurrences"
echo "  pyproject.toml: $(grep -c "$NEW" pyproject.toml)"
echo "  crates/zccache-watcher/pyproject.toml: $(grep -c "$NEW" crates/zccache-watcher/pyproject.toml)"
echo "  crates/zccache-fingerprint/pyproject.toml: $(grep -c "$NEW" crates/zccache-fingerprint/pyproject.toml)"

# Sanity check: no old version remaining
REMAINING=$(grep -c "$OLD" Cargo.toml pyproject.toml crates/zccache-watcher/pyproject.toml crates/zccache-fingerprint/pyproject.toml 2>/dev/null || echo "0")
if [ "$REMAINING" != "0" ]; then
    echo "WARNING: $REMAINING occurrences of old version $OLD still remain"
    grep -n "$OLD" Cargo.toml pyproject.toml crates/zccache-watcher/pyproject.toml crates/zccache-fingerprint/pyproject.toml 2>/dev/null
fi

echo "Done. Run: ./_cargo check --workspace && git add -A && git commit -m 'chore: bump to $NEW'"
