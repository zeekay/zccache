#!/usr/bin/env bash
# Bootstrap installer: finds python and runs install.py.
# After uv is installed, everything else uses uv.
set -e
cd "$(dirname "$0")"

# Try uv first, fall back to system python for bootstrapping
if command -v uv >/dev/null 2>&1; then
    exec uv run python install.py "$@"
fi
for py in python3 python; do
    if command -v "$py" >/dev/null 2>&1; then
        exec "$py" install.py "$@"
    fi
done
echo "error: No python found. Install python3 or uv first." >&2
exit 1
