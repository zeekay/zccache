#!/usr/bin/env bash
# install — Install the pinned Rust toolchain for zccache development.
#
# Usage: ./install
#
# Works on Linux, macOS, and Windows (MSYS2/Git Bash/Cygwin).
# Download tools tried in order from most universal to most OS-specific:
#   1. python3/python  (urllib — available almost everywhere)
#   2. curl
#   3. wget
#   4. powershell      (Windows-specific)

set -eo pipefail

# ── Pinned toolchain ────────────────────────────────────────────────────────
RUST_TOOLCHAIN="1.85.1"
RUSTUP_WIN_URL="https://static.rust-lang.org/rustup/dist/x86_64-pc-windows-msvc/rustup-init.exe"
RUSTUP_UNIX_URL="https://sh.rustup.rs"
# ────────────────────────────────────────────────────────────────────────────

log()  { printf '\033[1;32m[install]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[install]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[install]\033[0m %s\n' "$*" >&2; }
die()  { err "$@"; exit 1; }
has()  { command -v "$1" >/dev/null 2>&1; }

# ── Detect platform ────────────────────────────────────────────────────────

detect_platform() {
    case "$(uname -s)" in
        Linux*)                       PLATFORM="linux" ;;
        Darwin*)                      PLATFORM="macos" ;;
        MINGW*|MSYS*|CYGWIN*|*_NT*)  PLATFORM="windows" ;;
        *)  die "Unsupported platform: $(uname -s)" ;;
    esac
    log "Platform: $PLATFORM"
}

# ── Get a writable temp file path ──────────────────────────────────────────
# On MSYS2, mktemp returns /tmp/... which doesn't map to a real Windows path
# for binary writes. Use $USERPROFILE or $TEMP via cygpath instead.

make_tempfile() {
    local filename="${1:-zccache-tmp-$$}"
    if [ "$PLATFORM" = "windows" ] && has cygpath; then
        local wintemp
        wintemp="$(cygpath -u "${TEMP:-${USERPROFILE:-/tmp}}")"
        echo "${wintemp}/${filename}"
    else
        local dir
        dir="$(mktemp -d 2>/dev/null || echo /tmp)"
        echo "${dir}/${filename}"
    fi
}

# ── Download ────────────────────────────────────────────────────────────────
# Order: most universal → most OS-specific

download() {
    local url="$1" dest="$2"

    # On Windows, get the native path for tools that need it
    local native_dest="$dest"
    if [ "$PLATFORM" = "windows" ] && has cygpath; then
        native_dest="$(cygpath -w "$dest")"
    fi

    # 1. Python (most universal — works everywhere, handles paths natively)
    #    Try 'python' first — on Windows, the Chocolatey/system python is more
    #    likely to have SSL support than MSYS2's bundled python3.
    local py=""
    if has python && python -c "import ssl" 2>/dev/null; then
        py="python"
    elif has python3 && python3 -c "import ssl" 2>/dev/null; then
        py="python3"
    fi
    if [ -n "$py" ]; then
        log "Downloading via $py ..."
        "$py" -c "import urllib.request; urllib.request.urlretrieve('${url}', r'${native_dest}')" \
            && return 0
        warn "$py download failed, trying next ..."
    fi

    # 2. curl
    if has curl; then
        log "Downloading via curl ..."
        curl -fsSL --proto '=https' --tlsv1.2 -o "$native_dest" "$url" && return 0
        warn "curl download failed, trying next ..."
    fi

    # 3. wget
    if has wget; then
        log "Downloading via wget ..."
        wget -q -O "$native_dest" "$url" && return 0
        warn "wget download failed, trying next ..."
    fi

    # 4. PowerShell (Windows-specific)
    if has powershell; then
        log "Downloading via powershell ..."
        powershell -NoProfile -Command \
            "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri '${url}' -OutFile '${native_dest}'" \
            && return 0
        warn "powershell download failed ..."
    fi

    die "No working download method found. Install python3, curl, or wget."
}

# ── Source cargo env ────────────────────────────────────────────────────────

source_cargo_env() {
    # Standard Unix
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    fi
    # Windows: add .cargo/bin to PATH directly
    if [ "$PLATFORM" = "windows" ] && has cygpath; then
        local cargo_bin
        cargo_bin="$(cygpath -u "${USERPROFILE:-.}")/.cargo/bin"
        if [ -d "$cargo_bin" ]; then
            export PATH="${cargo_bin}:$PATH"
        fi
    fi
}

# ── Check current Rust version ──────────────────────────────────────────────

current_rust_version() {
    source_cargo_env
    if has rustc; then
        rustc --version 2>/dev/null | sed -n 's/.*\([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\).*/\1/p'
    fi
}

# ── Install rustup (fresh) ─────────────────────────────────────────────────

install_rustup() {
    local rustup_args="-y --default-toolchain ${RUST_TOOLCHAIN} --profile default -c clippy -c rustfmt"

    case "$PLATFORM" in
        linux|macos)
            log "Installing rustup via sh.rustup.rs ..."
            local tmp
            tmp="$(make_tempfile rustup-init.sh)"
            download "$RUSTUP_UNIX_URL" "$tmp"
            chmod +x "$tmp"
            RUSTUP_INIT_SKIP_PATH_CHECK=yes "$tmp" $rustup_args
            rm -f "$tmp"
            ;;
        windows)
            log "Installing rustup via rustup-init.exe ..."
            local tmp
            # Name MUST be rustup-init.exe — rustup uses argv[0] to decide behavior
            tmp="$(make_tempfile rustup-init.exe)"
            download "$RUSTUP_WIN_URL" "$tmp"
            log "Running rustup-init.exe ..."
            RUSTUP_INIT_SKIP_PATH_CHECK=yes "$tmp" $rustup_args
            rm -f "$tmp"
            ;;
    esac
}

# ── Verify ──────────────────────────────────────────────────────────────────

verify() {
    source_cargo_env

    if ! has rustc; then
        err "rustc not found on PATH after installation."
        err "Restart your terminal, then run:  rustc --version"
        return 1
    fi

    log ""
    log "rustc:   $(rustc --version)"
    log "cargo:   $(cargo --version)"
    has clippy-driver && log "clippy:  available" || warn "clippy: not found"
    has rustfmt       && log "rustfmt: available" || warn "rustfmt: not found"

    # Check for PATH shadowing: warn if a non-rustup rustc comes first
    local rustc_path
    rustc_path="$(command -v rustc 2>/dev/null || true)"
    case "$rustc_path" in
        */.cargo/bin/*)
            ;;  # correct — rustup-managed
        *)
            warn ""
            warn "WARNING: rustc at '$rustc_path' is NOT from rustup."
            warn "An old system Rust may shadow the rustup toolchain."
            warn "Fix by adding this to your shell profile:"
            if [ "$PLATFORM" = "windows" ]; then
                warn '  export PATH="/c/Users/'"${USERNAME:-$USER}"'/.cargo/bin:$PATH"'
            else
                warn '  export PATH="$HOME/.cargo/bin:$PATH"'
            fi
            warn ""
            warn "Or for this session only:"
            warn '  source "$HOME/.cargo/env"'
            ;;
    esac

    log ""
    log "Done. Run:  cargo check --workspace"
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    log "zccache — Rust toolchain installer"
    log "Pinned: Rust $RUST_TOOLCHAIN"
    log ""

    detect_platform

    # Already correct?
    local current
    current="$(current_rust_version)"
    if [ "${current:-}" = "$RUST_TOOLCHAIN" ]; then
        log "Rust $RUST_TOOLCHAIN already installed. Nothing to do."
        exit 0
    fi
    if [ -n "${current:-}" ]; then
        warn "Current rustc: $current (need $RUST_TOOLCHAIN)"
    fi

    # Rustup already present? Just switch toolchain.
    source_cargo_env
    if has rustup; then
        log "rustup found. Installing toolchain $RUST_TOOLCHAIN ..."
        rustup toolchain install "$RUST_TOOLCHAIN" --profile default -c clippy -c rustfmt
        rustup default "$RUST_TOOLCHAIN"
        verify
        exit 0
    fi

    # Fresh install
    log "rustup not found. Installing from scratch ..."
    install_rustup
    source_cargo_env
    verify || {
        warn ""
        warn "Restart your terminal, then run:"
        warn "  rustc --version"
        warn "  cargo check --workspace"
    }
}

main "$@"
