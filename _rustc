#!/bin/bash
# Trampoline: prefers the shared rustup proxy in ~/.cargo/bin when present.
if [ -n "${CARGO_HOME:-}" ]; then
  CARGO_BIN="$CARGO_HOME/bin"
elif [ -n "${HOME:-}" ]; then
  CARGO_BIN="$HOME/.cargo/bin"
elif [ -n "${USERPROFILE:-}" ]; then
  CARGO_BIN="$USERPROFILE/.cargo/bin"
else
  CARGO_BIN=""
fi

if [ -n "$CARGO_BIN" ] && [ -d "$CARGO_BIN" ]; then
  export PATH="$CARGO_BIN:$PATH"
fi

exec rustc "$@"
