{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ci/hooks/tool_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ci/hooks/readme_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uv run python ci/hooks/loc_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ci/hooks/check-on-start.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
